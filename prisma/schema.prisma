generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "linux-musl", "debian-openssl-1.1.x"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model aseguradora {
  id         Int          @id @default(autoincrement())
  nombre     String?      @db.VarChar
  logo       Bytes?
  expediente expediente[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model checklist {
  id                        Int              @id @default(autoincrement())
  no_siniestro              String?          @db.VarChar
  fecha_inspeccion          DateTime?        @db.Date
  hora                      DateTime?        @db.Time(6)
  inspeccionado_por         String?          @db.VarChar
  ubicacion                 String?          @db.VarChar
  aprobada                  Boolean?
  detallado                 Boolean?
  carroceo_asignado         String?          @db.VarChar
  mecanico_asignado         String?          @db.VarChar
  pintor                    String?          @db.VarChar
  area_detallado            String?          @db.VarChar
  marca_tipo                String?          @db.VarChar
  anio                      String?          @db.VarChar
  serie                     String?          @db.VarChar
  areas_danadas             String?
  a                         Boolean?
  t                         Boolean?
  fecha_vencimiento_seguro  DateTime?        @db.Date
  deducible                 Decimal?         @db.Decimal
  demerito                  Decimal?         @db.Decimal
  lugar_entrega             String?          @db.VarChar
  fecha_entrega             DateTime?        @db.Date
  nombre_quien_recibe       String?          @db.VarChar
  firma_quien_recibe        String?          @db.VarChar
  observaciones_adicionales String?
  expediente                expediente?      @relation(fields: [no_siniestro], references: [no_siniestro], onDelete: NoAction, onUpdate: NoAction)
  checklist_item            checklist_item[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model checklist_item {
  id           Int       @id @default(autoincrement())
  id_checklist Int
  sistema      String?   @db.VarChar
  nombre_item  String?   @db.VarChar
  valor        String?   @db.VarChar
  checklist    checklist @relation(fields: [id_checklist], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model evidencia {
  id                       Int            @id @default(autoincrement())
  no_siniestro             String         @db.VarChar
  tipo                     String?        @db.VarChar
  nombre_archivo           String?        @db.VarChar
  ruta                     String?
  fecha_carga              DateTime?      @default(now()) @db.Timestamp(6)
  ubicacion_almacenamiento ubicacion_enum @default(Local)
  subido_por               Int?
  expediente               expediente     @relation(fields: [no_siniestro], references: [no_siniestro], onDelete: NoAction, onUpdate: NoAction)
  usuario                  usuario?       @relation(fields: [subido_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model expediente {
  no_siniestro               String                 @id @db.VarChar
  factura                    String?                @db.VarChar
  orden                      String?                @db.VarChar
  asesor                     String?                @db.VarChar
  fecha_ingreso              DateTime?              @db.Date
  fecha_valuacion            DateTime?              @db.Date
  fecha_autorizacion         DateTime?              @db.Date
  fecha_pzas_completas       DateTime?              @db.Date
  unidad_terminada           DateTime?              @db.Date
  tecnico                    String?                @db.VarChar
  mecanico                   String?                @db.VarChar
  vehiculo                   String?                @db.VarChar
  observaciones              String?
  marca                      String?                @db.VarChar
  placas                     String?                @db.VarChar
  tipo                       String?                @db.VarChar
  color                      String?                @db.VarChar
  modelo                     String?                @db.VarChar
  nombre_cliente             String?                @db.VarChar
  telefono_cliente           String?                @db.VarChar
  correo_cliente             String?                @db.VarChar
  dato1                      String?                @db.VarChar(500)
  dato1_fecha_hora           DateTime?              @db.Timestamp(6)
  dato2                      String?                @db.VarChar(500)
  dato2_fecha_hora           DateTime?              @db.Timestamp(6)
  dato3                      String?                @db.VarChar(500)
  dato3_fecha_hora           DateTime?              @db.Timestamp(6)
  dato4                      String?                @db.VarChar(500)
  dato4_fecha_hora           DateTime?              @db.Timestamp(6)
  comentarios_aseguradora    String?
  comentarios_aseguradora_fh DateTime?              @db.Timestamp(6)
  doc_orden_admision         Boolean?
  doc_identificacion         Boolean?
  doc_tarjeta_circulacion    Boolean?
  doc_caratula_poliza        Boolean?
  doc_carta_reparacion       Boolean?
  doc_comprobante_deducible  Boolean?
  doc_finiquito              Boolean?
  doc_encuesta_servicio      Boolean?
  estado                     estado_enum            @default(Ingreso)
  ubicacion_almacenamiento   ubicacion_enum         @default(Local)
  id_aseguradora             Int?
  creado_por                 Int?
  fecha_entrega              DateTime?              @db.Date
  checklist                  checklist[]
  comentario                 comentario[]
  evidencia                  evidencia[]
  usuario                    usuario?               @relation(fields: [creado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  aseguradora                aseguradora?           @relation(fields: [id_aseguradora], references: [id], onDelete: NoAction, onUpdate: NoAction)
  historial_estado           historial_estado[]
  levantamiento_danios       levantamiento_danios[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model historial_estado {
  id              Int          @id @default(autoincrement())
  no_siniestro    String       @db.VarChar
  estado_anterior estado_enum?
  estado_nuevo    estado_enum
  fecha_cambio    DateTime     @default(now()) @db.Timestamp(6)
  cambiado_por    Int?
  usuario         usuario?     @relation(fields: [cambiado_por], references: [id], onDelete: NoAction, onUpdate: NoAction)
  expediente      expediente   @relation(fields: [no_siniestro], references: [no_siniestro], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model levantamiento_concepto {
  id                   Int                  @id @default(autoincrement())
  id_levantamiento     Int
  claves               String?              @db.VarChar
  concepto             String?              @db.VarChar
  costo                Decimal?             @db.Decimal
  levantamiento_danios levantamiento_danios @relation(fields: [id_levantamiento], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model levantamiento_danios {
  id                     Int                      @id @default(autoincrement())
  no_siniestro           String?                  @db.VarChar
  fecha                  DateTime?                @db.Date
  orden                  String?                  @db.VarChar
  marca                  String?                  @db.VarChar
  tipo                   String?                  @db.VarChar
  modelo                 String?                  @db.VarChar
  placas                 String?                  @db.VarChar
  kilometraje            String?                  @db.VarChar
  no_puertas             String?                  @db.VarChar
  color                  String?                  @db.VarChar
  serie                  String?                  @db.VarChar
  eco                    String?                  @db.VarChar
  asegurado_tercero      String?                  @db.VarChar
  nombre_propietario     String?                  @db.VarChar
  telefono               String?                  @db.VarChar
  direccion              String?                  @db.VarChar
  pega                   String?                  @db.VarChar
  cristales              Boolean?
  aire                   Boolean?
  vestiduras             Boolean?
  rin                    Boolean?
  direccion_veh          Boolean?
  tipo_pintura           Boolean?
  trasmision             Boolean?
  levantamiento_concepto levantamiento_concepto[]
  expediente             expediente?              @relation(fields: [no_siniestro], references: [no_siniestro], onDelete: NoAction, onUpdate: NoAction)
}

model usuario {
  id               Int                @id @default(autoincrement())
  nombre           String?            @db.VarChar
  username         String             @unique @db.VarChar
  password_hash    String             @db.VarChar
  rol              rol_enum
  comentario       comentario[]
  evidencia        evidencia[]
  expediente       expediente[]
  historial_estado historial_estado[]
}

/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model comentario {
  id             Int        @id @default(autoincrement())
  no_siniestro   String     @db.VarChar
  usuario_id     Int?
  fecha          DateTime   @default(dbgenerated("CURRENT_DATE")) @db.Date
  hora           DateTime   @default(dbgenerated("CURRENT_TIME")) @db.Time(6)
  comentario     String
  fecha_creacion DateTime   @default(now()) @db.Timestamp(6)
  expediente     expediente @relation(fields: [no_siniestro], references: [no_siniestro], onDelete: NoAction, onUpdate: NoAction)
  usuario        usuario?   @relation(fields: [usuario_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum estado_enum {
  Ingreso
  Restauracion
  Pendiente_de_salida
  Salida
}

enum rol_enum {
  Administrador
  Operador
  Tecnico
}

enum ubicacion_enum {
  Local
  Nube
}
