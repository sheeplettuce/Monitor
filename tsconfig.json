{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,

    "types": ["node"]
  },
  "include": ["src/**/*", "src/controllers/logs.controller.ts", "src/routes/logs.routes.ts"],
  "exclude": ["node_modules", "dist"]
}